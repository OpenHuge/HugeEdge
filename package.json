{
  "name": "hugeedge",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.11.1",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "generate": "pnpm --filter @hugeedge/api-client generate",
    "lint": "biome check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "validate:capabilities": "tsx infra/scripts/validate-json.ts contracts/capabilities/schema.json contracts/capabilities/example.json",
    "validate:policy-packs": "tsx infra/scripts/validate-json.ts contracts/remediation/policy.schema.json contracts/remediation/example-policy.json",
    "validate:wasm-artifacts": "tsx infra/scripts/validate-json.ts contracts/wasm/plugin-manifest.schema.json contracts/wasm/example-plugin.json",
    "validate:probe-profiles": "tsx infra/scripts/validate-json.ts contracts/ebpf/probe-profile.schema.json contracts/ebpf/example-profile.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "2.29.8",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "ajv": "8.17.1",
    "tsx": "4.21.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
